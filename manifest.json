{
  "manifest_version": 3,
  "name": "Quick Translate",
  "version": "0.1.0",
  "description": "Instant translation on right-click selection",
  "homepage_url": "https://github.com/Vastargazing/quick_translate",
  "developer": {
    "name": "Vastargazing",
    "url": "https://github.com/Vastargazing"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-translate@vastargazing",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "worker/translations-engine.worker.js",
        "engine/translations-engine.js",
        "wasm/bergamot-translator.wasm",
        "wasm/bergamot-translator.js",
        "models/*",
        "icons/*",
        "fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}